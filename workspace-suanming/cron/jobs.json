{
  "workspace": "suanming",
  "description": "算命喵 Agent 定时任务配置",
  "timezone": "Asia/Shanghai",
  "jobs": [
    {
      "id": "suanming-daily-fortune-08",
      "agentId": "suanming",
      "name": "算命-每日早运推送",
      "description": "每天 08:00 执行 morning-fortune.sh，获取黄历干支、结合用户八字推算当日运势，推送到飞书",
      "schedule": {
        "kind": "cron",
        "expr": "0 8 * * *",
        "tz": "Asia/Shanghai"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "daily-fortune"
      },
      "delivery": {
        "mode": "silent"
      }
    }
  ],
  "notes": {
    "date_variables": {
      "{{DATE}}": "当前日期（YYYY-MM-DD）",
      "{{YESTERDAY}}": "前一天日期（YYYY-MM-DD）"
    },
    "action_types": {
      "agentTurn": "触发 Agent 处理意图，由 routing.js 路由到 core.js"
    },
    "future_jobs": [
      "TODO: 可在此添加其他定时任务（如每周运势总结、节气推送等）"
    ]
  }
}
